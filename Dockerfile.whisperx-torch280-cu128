# syntax=docker/dockerfile:1.7

FROM nvidia/cuda:12.8.1-cudnn-devel-ubuntu22.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
      ca-certificates \
      build-essential \
      software-properties-common \
      ffmpeg \
      git \
    && if apt-cache show python3.11 >/dev/null 2>&1; then \
      apt-get install -y --no-install-recommends python3.11 python3.11-venv; \
    else \
      add-apt-repository -y ppa:deadsnakes/ppa >/dev/null && \
      apt-get update && \
      apt-get install -y --no-install-recommends python3.11 python3.11-venv; \
    fi \
    && rm -rf /var/lib/apt/lists/*

RUN python3.11 -m venv /opt/venv
ENV PATH="/opt/venv/bin:${PATH}"

RUN pip install --upgrade pip setuptools wheel

# Core stack pinned to the requested CUDA 12.8 + torch 2.8.0 + whisper stack.
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --no-cache-dir --index-url https://download.pytorch.org/whl/cu128 \
      "torch==2.8.0+cu128" \
      "torchaudio==2.8.0+cu128" \
      "triton>=3.3.0"

RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --no-cache-dir \
      "ctranslate2==4.7.1" \
      "faster-whisper==1.2.1" \
      "whisperx==3.8.2" \
      "huggingface-hub<1.0.0" \
      "transformers>=4.48.0" \
      "pyannote-audio==4.0.4"

RUN python - <<'PY'
import torch
import torchaudio
import ctranslate2
import faster_whisper
import whisperx
import pyannote
import transformers
import triton
from importlib.metadata import version

def _module_version(mod, name):
    return getattr(mod, name, "unknown")

def _package_version(name):
    try:
        return version(name)
    except Exception:
        return "unknown"

print("torch", torch.__version__, torch.version.cuda, torch.cuda.get_device_name() if torch.cuda.is_available() else "no-gpu")
print("torchaudio", torchaudio.__version__)
print("ct2", ctranslate2.__version__)
print("faster-whisper", faster_whisper.__version__)
print("whisperx", _module_version(whisperx, "__version__") or _package_version("whisperx"))
print("pyannote", _package_version("pyannote-audio"))
print("transformers", transformers.__version__)
print("triton", triton.__version__)
PY

FROM nvidia/cuda:12.8.1-cudnn-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    HF_HOME=/cache/hf \
    TRANSFORMERS_CACHE=/cache/hf \
    TORCH_HOME=/cache/torch \
    XDG_CACHE_HOME=/cache/xdg

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
      ca-certificates \
      ffmpeg \
      software-properties-common \
    && rm -rf /var/lib/apt/lists/*

RUN apt-get update \
    && if apt-cache show python3.11 >/dev/null 2>&1; then \
      apt-get install -y --no-install-recommends python3.11 python3.11-venv; \
    else \
      add-apt-repository -y ppa:deadsnakes/ppa >/dev/null && \
      apt-get update && \
      apt-get install -y --no-install-recommends python3.11 python3.11-venv; \
    fi \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:${PATH}"

WORKDIR /work
ENTRYPOINT ["bash", "-lc"]
CMD ["whisperx --help"]
