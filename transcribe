def bool_to_str(value: bool) -> str:
  return "True" if value else "False"


def normalize_cli_value(value: object) -> Optional[str]:
  if value is None:
    return None
  if isinstance(value, bool):
    return bool_to_str(value)
  return str(value)


def ensure_dir(path: str) -> None:
  Path(path).mkdir(parents=True, exist_ok=True)


def is_positive_int(value: object) -> bool:
  try:
    i = int(str(value))
  except (TypeError, ValueError):
    return False
  return i > 0


def parse_int(value: object) -> int:
  return int(str(value))


def to_csv_list(value: str) -> List[str]:
  return [item.strip() for item in value.split(",") if item.strip()]


def parse_output_format(raw: str) -> List[str]:
  if not raw or raw == "all":
    return list(DEFAULT_OUTPUT_EXTS)
  return to_csv_list(raw)


def parse_cuda_devices(raw: str) -> List[str]:
  if not raw:
    return []
  return to_csv_list(raw)


