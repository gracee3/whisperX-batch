  return resolve_transcribe_defaults(args)


def find_audio_files(input_dir: Path, recursive: bool) -> List[Path]:
  files = []
  pattern: Sequence[Path] = input_dir.rglob("*") if recursive else input_dir.glob("*")
  for candidate in pattern:
    if not candidate.is_file():
      continue
    if candidate.suffix.lower() not in SUPPORTED_EXTENSIONS:
      continue
    files.append(candidate)
  return sorted(files)


def build_docker_run_command(
  image: str,
  pull_policy: str,
  host_output_dir: str,
  host_cuda_devices: List[str],
  host_model_mounts: Sequence[str],
  host_cache: str,
  host_inputs: Sequence[Tuple[Path, str]],
  whisper_args: Sequence[str],
  whisper_output_dir: str,
  whisper_input_container_dir: str,
) -> List[str]:
  cmd: List[str] = [
    "docker",
    "run",
    "--rm",
    "--interactive",
    "--pull",
    pull_policy,
    "-u",
    f"{os.getuid()}:{os.getgid()}",
  ]

  if not host_cuda_devices:
    cmd += ["--gpus", "all"]
  else:
    cmd += ["--gpus", f"device={','.join(host_cuda_devices)}"]

  cmd += [
    "-v",
    f"{Path(host_output_dir).resolve()}:/mnt/output",
    "-v",
    f"{Path(host_cache).resolve()}:/cache",
    "-e",
    "HF_HUB_OFFLINE=1",
    "-e",
    "HF_DATASETS_OFFLINE=1",
    "-e",
    "TRANSFORMERS_OFFLINE=1",
    "-e",
    "HF_HOME=/cache/hf",
    "-e",
    "TRANSFORMERS_CACHE=/cache/hf",
    "-e",
    "TORCH_HOME=/cache/torch",
    "-e",
    "XDG_CACHE_HOME=/cache/xdg",
    "-e",
    "NLTK_DATA=/cache/nltk_data",
    "-e",
    "MPLCONFIGDIR=/tmp/matplotlib",
  ]

  for mount in sorted(set(host_model_mounts)):
    cmd.extend(("-v", f"{Path(mount).resolve()}:{Path(mount).resolve()}:ro"))

  for input_path, mapped_name in host_inputs:
    cmd.extend(("-v", f"{input_path.resolve()}:{whisper_input_container_dir}/{mapped_name}:ro"))

  whisper_cmd = list(whisper_args)
  whisper_cmd.extend(["--output_dir", whisper_output_dir])
  whisper_cmd.extend((f"{whisper_input_container_dir}/{mapped_name}" for _, mapped_name in host_inputs))

  cmd.append(image)
  cmd.append(build_shell_command(whisper_cmd))
  return cmd


def execute_docker(cmd: List[str]) -> int:
  proc = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)
  if proc.returncode != 0:
    if proc.stdout:
      print(proc.stdout)
  return proc.returncode


def run_docker_batch(
  batch_inputs: Sequence[Tuple[Path, str]],
  image: str,
  pull_policy: str,
  output_dir: Path,
  cache_scope: str,
  cuda_devices: List[str],
  model_mounts: Sequence[str],
  whisper_args: Sequence[str],
  whisper_input_container_dir: str,
  diarize: bool,
) -> int:
  batch_docker_cmd = build_docker_run_command(
    image=image,
    pull_policy=pull_policy,
    host_output_dir=str(output_dir),
    host_cuda_devices=[str(dev) for dev in cuda_devices],
    host_model_mounts=model_mounts,
    host_cache=cache_scope,
    host_inputs=batch_inputs,
    whisper_args=whisper_args,
    whisper_output_dir="/mnt/output",
    whisper_input_container_dir=whisper_input_container_dir,
  )
  if os.environ.get("WHISPERX_DEBUG") == "1":
    print("DEBUG: docker run command:")
    print("  ", end="")
    print(" ".join(f"{arg!s}" for arg in batch_docker_cmd))
  status = execute_docker(batch_docker_cmd)

  if status != 0 and diarize:
    fallback_whisper_args = [arg for arg in whisper_args if arg not in {"--diarize"}]
    fallback_docker_cmd = build_docker_run_command(
      image=image,
      pull_policy=pull_policy,
      host_output_dir=str(output_dir),
      host_cuda_devices=[str(dev) for dev in cuda_devices],
      host_model_mounts=model_mounts,
      host_cache=cache_scope,
      host_inputs=batch_inputs,
      whisper_args=fallback_whisper_args,
      whisper_output_dir="/mnt/output",
      whisper_input_container_dir=whisper_input_container_dir,
    )
    return execute_docker(fallback_docker_cmd)

  return status


def run() -> int:
  args = parse_args()
  values = apply_defaults(args)

  input_dir = Path(str(values["input_dir"]))
  output_dir = Path(str(values["output_dir"])).expanduser()
  cuda_devices = parse_cuda_devices(str(values["cuda_devices"]))
  output_format = str(values["output_format"])
  output_exts = parse_output_format(output_format)

  if not input_dir.is_dir():
    print(f"ERROR: input directory not found: {input_dir}", file=sys.stderr)
    return 2
  ensure_dir(str(output_dir))
  if not output_dir.is_dir():
    print(f"ERROR: output directory not writable: {output_dir}", file=sys.stderr)
    return 2

  model = str(values["model"])
  if not os.path.isabs(model):
    model = str(Path(model).resolve())
  model_path = Path(model).expanduser()
  if not model_path.exists():
    print(f"ERROR: --model not found: {model}", file=sys.stderr)
    return 2

  diarize = bool(values["diarize"])
  diarize_model = str(values["diarize_model"])
  if diarize:
    if not os.path.isabs(diarize_model):
      diarize_model = str(Path(diarize_model).resolve())
    if not Path(diarize_model).exists():
      print(f"ERROR: --diarize-model not found: {diarize_model}", file=sys.stderr)
      return 2

  align_model = str(values["align_model"])
  if align_model and "/" in align_model:
    align_path = Path(align_model)
    if not align_path.is_absolute():
      align_path = align_path.expanduser().resolve()
    if not align_path.exists():
      print(f"ERROR: --align-model not found: {align_model}", file=sys.stderr)
      return 2
    align_model = str(align_path)

  try:
    check_large_v3_layout(model_path)
  except ValueError as exc:
    print(f"ERROR: {exc}", file=sys.stderr)
    return 2

  batch_size = parse_int(values["batch_size"])
  if batch_size <= 0:
    print("--batch-size must be >= 1", file=sys.stderr)
    return 2

  for opt_name, raw in (
    ("max_speakers", values["max_speakers"]),
    ("min_speakers", values["min_speakers"]),
  ):
    if str(raw):
      if not is_positive_int(raw):
        print(f"ERROR: --{opt_name} must be a positive integer.", file=sys.stderr)
        return 2

  input_files = find_audio_files(input_dir, bool(values["recursive"]))
  if not input_files:
    print(f"No input files found in {input_dir} with extensions: {', '.join(sorted(SUPPORTED_EXTENSIONS))}", file=sys.stderr)
    return 0

  if str(values["device"]).startswith(SUPPORTED_DEVICE_PREFIX):
    if not cuda_devices:
      cuda_devices = ["0"]
  else:
    cuda_devices = []

  mapped_inputs = build_container_input_names(input_files)

  skip_existing = bool(values["skip_transcribe_existing"])
  pending_files: List[Tuple[Path, str]] = []
  for audio, container_name in mapped_inputs:
    if skip_existing and output_exists(output_dir, container_name, output_exts):
      print(f"Skipping transcribe (exists): {audio}")
      continue
    pending_files.append((audio, container_name))

  if not pending_files:
    print("No files to transcribe (all outputs already exist).")
    return 0

  whisper_args = build_whisper_args(
    model=str(model_path),
    task=str(values["task"]),
    language=str(values["language"]),
    output_format=output_format,
    device=str(values["device"]),
    compute_type=str(values["compute_type"]),
    batch_size=batch_size,
    max_speakers=str(values["max_speakers"]),
    align_model=str(align_model),
    interpolate_method=str(values["interpolate_method"]),
    no_align=bool(values["no_align"]),
    return_char_alignments=bool(values["return_char_alignments"]),
    vad_method=str(values["vad_method"]),
    vad_onset=str(values["vad_onset"]),
    vad_offset=str(values["vad_offset"]),
    chunk_size=str(values["chunk_size"]),
    diarize=diarize,
    diarize_model=str(diarize_model),
    speaker_embeddings=bool(values["speaker_embeddings"]),
    temperature=str(values["temperature"]),
    best_of=str(values["best_of"]),
    beam_size=str(values["beam_size"]),
    patience=str(values["patience"]),
    length_penalty=str(values["length_penalty"]),
    suppress_tokens=str(values["suppress_tokens"]),
    suppress_numerals=bool(values["suppress_numerals"]),
    initial_prompt=str(values["initial_prompt"]),
    condition_on_previous_text=str(values["condition_on_previous_text"]),
    fp16=str(values["fp16"]),
    temperature_increment_on_fallback=str(values["temperature_increment_on_fallback"]),
    compression_ratio_threshold=str(values["compression_ratio_threshold"]),
    logprob_threshold=str(values["logprob_threshold"]),
    no_speech_threshold=str(values["no_speech_threshold"]),
    max_line_width=str(values["max_line_width"]),
    max_line_count=str(values["max_line_count"]),
    highlight_words=bool(values["highlight_words"]),
    segment_resolution=str(values["segment_resolution"]),
    min_speakers=str(values["min_speakers"]),
    threads=str(values["threads"]),
    print_progress=str(values["print_progress"]),
    verbose=str(values["verbose"]),
    log_level=str(values["log_level"]),
    hotwords=str(values["hotwords"]),
    extra_args=list(values["extra_args"]),
  )

  docker_cache = str(values["docker_cache"])
  temp_cache: Optional[tempfile.TemporaryDirectory[str]] = None
  try:
    cache_scope, fallback = mount_cache(docker_cache)
  except PermissionError:
    temp_cache = tempfile.TemporaryDirectory(prefix="whisperx-cache-")
    cache_scope = temp_cache.name
    for sub in ("hf", "torch", "xdg", "nltk_data"):
      (Path(cache_scope) / sub).mkdir(parents=True, exist_ok=True)
    fallback = True

  if fallback:
    print(f"WARNING: cache root not writable ({docker_cache}); using temporary cache {cache_scope}", file=sys.stderr)

  if shutil.which("docker") is None:
    print("ERROR: docker is required for this tool.", file=sys.stderr)
    if temp_cache is not None:
      temp_cache.cleanup()
    return 2

  image = str(values["docker_image"])
  if values["docker_pull_policy"] not in {"always", "missing"}:
    print("ERROR: --docker-pull-policy must be one of always|missing", file=sys.stderr)
    if temp_cache is not None:
      temp_cache.cleanup()
    return 2

  model_mounts = collect_mount_ro_paths(
    [str(model_path), str(diarize_model), str(align_model)],
  )

  # Keep first mapped input names visible for user.
  print(f"Mode: docker (single process)")
  print(f"Input directory: {input_dir}")
  print(f"Output directory: {output_dir}")
  print(f"Files to transcribe: {len(pending_files)}")
  max_docker_files_raw = os.environ.get("WHISPERX_MAX_DOCKER_FILES", str(DEFAULT_MAX_DOCKER_FILES))
  try:
    max_docker_files = int(max_docker_files_raw)
  except ValueError:
    print(
      f"WARNING: invalid WHISPERX_MAX_DOCKER_FILES={max_docker_files_raw!r}; using default {DEFAULT_MAX_DOCKER_FILES}.",
      file=sys.stderr,
    )
    max_docker_files = DEFAULT_MAX_DOCKER_FILES
  if max_docker_files < 1:
    max_docker_files = DEFAULT_MAX_DOCKER_FILES

  input_batches = chunk_inputs(pending_files, max_docker_files)
  if len(input_batches) > 1:
    print(
      f"Input batching active: splitting {len(pending_files)} files into {len(input_batches)} docker run(s)"
      f" (max files per run: {max_docker_files})."
    )

  if os.environ.get("WHISPERX_DEBUG") == "1":
    print(f"Using WHISPERX_MAX_DOCKER_FILES={max_docker_files}")

  try:
    for batch_idx, batch_inputs in enumerate(input_batches, start=1):
      print(f"Running docker batch {batch_idx}/{len(input_batches)}: {len(batch_inputs)} files")
      status = run_docker_batch(
        batch_inputs=batch_inputs,
        image=image,
        pull_policy=str(values["docker_pull_policy"]),
        output_dir=output_dir,
        cache_scope=cache_scope,
        cuda_devices=[str(dev) for dev in cuda_devices],
        model_mounts=model_mounts,
        whisper_args=whisper_args,
        whisper_input_container_dir="/mnt/input",
        diarize=diarize,
      )
      if status != 0:
        print(f"Batch {batch_idx} failed with status {status}", file=sys.stderr)
        return status
  finally:
    if temp_cache is not None:
      temp_cache.cleanup()

  return 0


if __name__ == "__main__":
  raise SystemExit(run())
