  model: str,
  task: str,
  language: str,
  output_format: str,
  device: str,
  compute_type: str,
  batch_size: int,
  max_speakers: str,
  align_model: str,
  interpolate_method: str,
  no_align: bool,
  return_char_alignments: bool,
  vad_method: str,
  vad_onset: str,
  vad_offset: str,
  chunk_size: str,
  diarize: bool,
  diarize_model: str,
  speaker_embeddings: bool,
  temperature: str,
  best_of: str,
  beam_size: str,
  patience: str,
  length_penalty: str,
  suppress_tokens: str,
  suppress_numerals: bool,
  initial_prompt: str,
  condition_on_previous_text: str,
  fp16: str,
  temperature_increment_on_fallback: str,
  compression_ratio_threshold: str,
  logprob_threshold: str,
  no_speech_threshold: str,
  max_line_width: str,
  max_line_count: str,
  highlight_words: bool,
  segment_resolution: str,
  min_speakers: str,
  threads: str,
  print_progress: str,
  verbose: str,
  log_level: str,
  hotwords: str,
  extra_args: List[str],
) -> List[str]:
  args = [
    "whisperx",
    "--model",
    model,
    "--task",
    task,
    "--language",
    language,
    "--output_format",
    output_format,
    "--device",
    device,
    "--compute_type",
    compute_type,
    "--batch_size",
    str(batch_size),
  ]

  def append_if_present(flag: str, value: object) -> None:
    normalized = normalize_cli_value(value)
    if normalized:
      args.extend((flag, normalized))

  def append_boollike(flag: str, value: object) -> None:
    parsed = parse_bool(value)
    if parsed is None:
      append_if_present(flag, value)
      return
    args.extend((flag, bool_to_str(parsed)))

  args.extend(("--align_model", align_model) if align_model else ())
  append_if_present("--interpolate_method", interpolate_method)
  if no_align:
    args.append("--no_align")
  if return_char_alignments:
