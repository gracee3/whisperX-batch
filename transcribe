  append_if_present("--max_speakers", max_speakers)
  append_if_present("--min_speakers", min_speakers)
  if diarize:
    if diarize_model:
      args.extend(["--diarize_model", diarize_model])
    args.append("--diarize")
  if speaker_embeddings:
    args.append("--speaker_embeddings")
  append_if_present("--temperature", temperature)
  append_if_present("--best_of", best_of)
  append_if_present("--beam_size", beam_size)
  append_if_present("--patience", patience)
  append_if_present("--length_penalty", length_penalty)
  append_if_present("--suppress_tokens", suppress_tokens)
  if suppress_numerals:
    args.append("--suppress_numerals")
  append_if_present("--initial_prompt", initial_prompt)
  append_boollike("--condition_on_previous_text", condition_on_previous_text)
  append_boollike("--fp16", fp16)
  append_if_present("--temperature_increment_on_fallback", temperature_increment_on_fallback)
  append_if_present("--compression_ratio_threshold", compression_ratio_threshold)
  append_if_present("--logprob_threshold", logprob_threshold)
  append_if_present("--no_speech_threshold", no_speech_threshold)
  append_if_present("--max_line_width", max_line_width)
  append_if_present("--max_line_count", max_line_count)
  if highlight_words:
    args.append("--highlight_words")
  append_if_present("--segment_resolution", segment_resolution)
  append_if_present("--threads", threads)
  append_boollike("--print_progress", print_progress)
  append_if_present("--verbose", verbose)
  append_if_present("--log-level", log_level)
  append_if_present("--hotwords", hotwords)

  args.extend(extra_args)
  return args


def build_container_input_names(input_files: Sequence[Path]) -> List[Tuple[Path, str]]:
  seen: Dict[str, int] = {}
  out: List[Tuple[Path, str]] = []
  for audio in input_files:
    name = audio.name
    count = seen.get(name, 0)
    seen[name] = count + 1
    mapped_name = name if count == 0 else f"{audio.stem}_{count}{audio.suffix}"
    out.append((audio, mapped_name))
  return out


def output_exists(output_dir: Path, mapped_name: str, exts: Sequence[str]) -> bool:
  stem = Path(mapped_name).with_suffix("").name
  for ext in exts:
    if (output_dir / f"{stem}.{ext}").exists():
      return True
  return False


def chunk_inputs(
  items: Sequence[Tuple[Path, str]],
  chunk_size: int,
) -> List[Sequence[Tuple[Path, str]]]:
  if chunk_size <= 0:
    return [items]
  return [list(items[i : i + chunk_size]) for i in range(0, len(items), chunk_size)]


def mount_cache(cache_dir: str) -> Tuple[str, bool]:
  cache_path = Path(cache_dir).expanduser()
  cache_path.mkdir(parents=True, exist_ok=True)
  scope = cache_path
  if not os.access(scope, os.W_OK):
    raise PermissionError(f"cache dir is not writable: {scope}")

  for sub in ("hf", "torch", "xdg", "nltk_data"):
    (scope / sub).mkdir(parents=True, exist_ok=True)
  return str(scope), False


def check_large_v3_layout(model_path: Path) -> None:
  if "large-v3" not in model_path.name and "large-v3" not in str(model_path):
    return
  if not model_path.is_dir():
    raise ValueError(f"--model '{model_path}' is not a directory")
  if not (model_path / "model.bin").exists():
    raise ValueError(
      "large-v3 requires CTranslate2 model.bin layout and is not compatible with raw HF checkpoints.",
    )
  if not ((model_path / "preprocessor_config.json").exists() or (model_path / "processor_config.json").exists()):
    raise ValueError(
      "large-v3 requires preprocessor_config.json or processor_config.json to prevent 80/128-mel mismatch.",
    )


def collect_mount_ro_paths(paths: Sequence[str]) -> List[str]:
  mounts: Dict[str, None] = {}
  for raw in paths:
    if not raw:
      continue
    p = Path(raw).expanduser()
    if not p.is_absolute():
      p = p.resolve()
    if not p.exists():
      continue
    mount_root = p if p.is_dir() else p.parent
    mounts[str(mount_root)] = None
  return sorted(mounts.keys())


def shell_quote(value: str) -> str:
  return "'" + value.replace("'", "'\\''") + "'"


def build_shell_command(args: Sequence[str]) -> str:
  return " ".join(shell_quote(arg) for arg in args)


